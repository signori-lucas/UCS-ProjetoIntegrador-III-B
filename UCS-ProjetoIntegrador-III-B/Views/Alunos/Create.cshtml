@model UCS_ProjetoIntegrador_III_B.Entities.Aluno

@{
    ViewData["Title"] = "Novo Aluno";
}

<h2>Criar Aluno</h2>

<form asp-action="Create" method="post">
    <div class="form-group mb-2">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="form-group mb-2">
        <label asp-for="Matricula" class="form-label"></label>
        <input asp-for="Matricula" class="form-control" />
    </div>
    <div class="form-group mb-2">
        <label asp-for="CPF" class="form-label"></label>
        <input asp-for="CPF" class="form-control" />
        <span asp-validation-for="CPF" class="text-danger"></span>
    </div>
    <div class="form-group mb-2">
        <label asp-for="DataNascimento" class="form-label"></label>
        <input asp-for="DataNascimento" type="date" class="form-control" />
    </div>
    <div class="form-group mb-2">
        <label asp-for="Endereco" class="form-label"></label>
        <input asp-for="Endereco" class="form-control" />
    </div>
    <div class="form-group mb-2">
        <label asp-for="Sexo" class="form-label"></label>
        <select asp-for="Sexo" class="form-select">
            <option value="">--Selecione--</option>
            <option value="Masculino">Masculino</option>
            <option value="Feminino">Feminino</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
