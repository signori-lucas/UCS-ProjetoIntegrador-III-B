@model UCS_ProjetoIntegrador_III_B.Entities.Estagio

@{
    ViewData["Title"] = "Editar Estágio";
}

<h2>Editar Estágio</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-group mb-2">
        <label asp-for="Titulo" class="form-label"></label>
        <input asp-for="Titulo" class="form-control" />
        <span asp-validation-for="Titulo" class="text-danger"></span>
    </div>
    <div class="form-group mb-2">
        <label asp-for="Descricao" class="form-label"></label>
        <textarea asp-for="Descricao" class="form-control"></textarea>
    </div>
    <div class="form-group mb-2">
        <label class="form-label">Empresa</label>
        <select asp-for="EmpresaId" asp-items="ViewBag.Empresas" class="form-select"></select>
    </div>
    <div class="form-group mb-2">
        <label class="form-label">Orientador</label>
        <select asp-for="OrientadorId" asp-items="ViewBag.Orientadores" class="form-select"></select>
    </div>
    <div class="form-group mb-2">
        <label class="form-label">Alunos</label>
        <div>
            @foreach (var aluno in (IEnumerable<UCS_ProjetoIntegrador_III_B.Entities.Aluno>)ViewBag.Alunos)
            {
                var isChecked = Model.Alunos != null && Model.Alunos.Any(a => a.Id == aluno.Id);
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="selectedAlunos" value="@aluno.Id" id="aluno_@aluno.Id" @(isChecked ? "checked" : "") />
                    <label class="form-check-label" for="aluno_@aluno.Id">@aluno.Nome</label>
                </div>
            }
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
