@model UCS_ProjetoIntegrador_III_B.Entities.Estagio

@{
    ViewData["Title"] = "Detalhes do Estágio";
}

<h2>Detalhes</h2>

<div>
    <h4>Estágio</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Título</dt>
        <dd class="col-sm-10">@Model.Titulo</dd>

        <dt class="col-sm-2">Descrição</dt>
        <dd class="col-sm-10">@Model.Descricao</dd>

        <dt class="col-sm-2">Empresa</dt>
        <dd class="col-sm-10">@Model.Empresa?.Nome</dd>

        <dt class="col-sm-2">Orientador</dt>
        <dd class="col-sm-10">@Model.Orientador?.Nome</dd>

        <dt class="col-sm-2">Alunos</dt>
        <dd class="col-sm-10">
            <ul>
            @if (Model.Alunos != null && Model.Alunos.Any())
            {
                foreach (var a in Model.Alunos)
                {
                    <li>@a.Nome</li>
                }
            }
            else
            {
                <li>Nenhum aluno associado</li>
            }
            </ul>
        </dd>
    </dl>
</div>

<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</p>
