@model UCS_ProjetoIntegrador_III_B.Entities.Estagio

@{
    ViewData["Title"] = "Excluir Estágio";
}

<h2>Excluir</h2>

<h3>Tem certeza que deseja excluir este estágio?</h3>
<div>
    <h4>Estágio</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Título</dt>
        <dd class="col-sm-10">@Model.Titulo</dd>
        <dt class="col-sm-2">Empresa</dt>
        <dd class="col-sm-10">@Model.Empresa?.Nome</dd>
    </dl>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Excluir</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
